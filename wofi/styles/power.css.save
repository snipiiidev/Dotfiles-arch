vbody{
  margin:0;
  background: linear-gradient(to right, #e9b3b3, #e6a08c);
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
  font-family: Arial, sans-serif;
}

.card{
  text-align:center;
  background:white;
  padding:40px;
  border-radius:15px;
  box-shadow:0 10px 30px rgba(0,0,0,0.2);
}

.subtitle{
  color:#666;
}

button{
  padding:10px 20px;
  margin:10px;
  border:none;
  border-radius:8px;
  cursor:pointer;
  font-size:16px;
}

#yesBtn{
  background:#ff4d6d;
  color:white;
}

#noBtn{
  background:#ccc;
}

.modal{
  display:none;
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.5);
  justify-content:center;
  align-items:center;
}

.modal-content{
  background:white;
  padding:30px;
  border-radius:10px;
  text-align:center;
}
